<Page
    x:Class="App4.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App4"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12" MaxWidth="620">

            <!-- Status -->
            <TextBlock x:Name="TxtStatus" Text="Ready for action?" FontSize="20"
                       Margin="0,0,0,8" TextWrapping="Wrap" TextAlignment="Center" />

            <!-- Windows Hello -->
            <Button Content="Verify Windows Hello"
                    Click="VerifyHello_Button_Click"
                    FontSize="18" Padding="20,10" HorizontalAlignment="Stretch"/>

            <!-- Browser Extension row -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Launch Browser Extension"
                        Click="LaunchBrowserExt_Button_Click"
                        FontSize="16" Padding="16,10" HorizontalAlignment="Stretch"/>
                <Button Grid.Column="2" Content="Send Command"
                        Click="SendBrowserExt_Button_Click"
                        FontSize="16" Padding="16,10" HorizontalAlignment="Stretch"/>
            </Grid>

            <!-- TPM row -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Launch TPM"
                        Click="LaunchTpm_Button_Click"
                        FontSize="16" Padding="16,10" HorizontalAlignment="Stretch"/>
                <Button Grid.Column="2" Content="Send TPM Query"
                        Click="SendTpm_Button_Click"
                        FontSize="16" Padding="16,10" HorizontalAlignment="Stretch"/>
            </Grid>

            <!-- TPM version check — local only, no pipe needed -->
            <Button Content="Check TPM Version (local)"
                    Click="CheckTpmVersion_Button_Click"
                    FontSize="16" Padding="16,10" HorizontalAlignment="Stretch"/>

            <!-- Write test row -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="UWP Write"
                        Click="TestUwpWrite_Button_Click"
                        FontSize="14" Padding="12,10" HorizontalAlignment="Stretch"/>
                <Button Grid.Column="2" Content="FullTrust Write"
                        Click="TestFullTrustWrite_Button_Click"
                        FontSize="14" Padding="12,10" HorizontalAlignment="Stretch"/>
                <Button Grid.Column="4" Content="Admin Write (UAC)"
                        Click="TestAdminWrite_Button_Click"
                        FontSize="14" Padding="12,10" HorizontalAlignment="Stretch"/>
            </Grid>

        </StackPanel>
    </Grid>
</Page>
